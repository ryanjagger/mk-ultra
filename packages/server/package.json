{
  "name": "@mk/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs --external:bufferutil --external:utf-8-validate",
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mk/shared": "workspace:*",
    "@mk/sim": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.0",
    "esbuild": "^0.27.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
